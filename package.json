{
  "name": "@metyatech/docusaurus-microsoft-auth",
  "version": "0.1.1",
  "description": "Microsoft Entra ID (Azure AD) authentication integration for Docusaurus sites using MSAL.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "require": "./dist/client/index.js",
      "import": "./dist/client/index.js"
    },
    "./client/*": {
      "types": "./dist/client/*.d.ts",
      "require": "./dist/client/*.js",
      "import": "./dist/client/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && npm run copy:assets",
    "clean": "rimraf dist",
    "copy:assets": "node ./scripts/copy-assets.cjs",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.json\" \"*.md\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --check",
      "eslint"
    ],
    "*.{json,md}": [
      "prettier --check"
    ]
  },
  "peerDependencies": {
    "@azure/msal-browser": "^4.24.0",
    "@azure/msal-react": "^3.0.0",
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/types": "^3.0.0",
    "clsx": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "clsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@azure/msal-browser": "^4.24.0",
    "@azure/msal-react": "^3.0.0",
    "@docusaurus/core": "^3.9.1",
    "@docusaurus/module-type-aliases": "^3.9.1",
    "@docusaurus/types": "^3.9.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "clsx": "^2.1.1",
    "eslint": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  },
  "license": "MIT"
}
